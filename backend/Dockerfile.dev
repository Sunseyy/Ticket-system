# ─────────────────────────────────────────────────────────────────────────────
# Backend Dockerfile - Development (with volume mounts)
# ─────────────────────────────────────────────────────────────────────────────

FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy source files
COPY . .

# Create uploads directory
RUN mkdir -p /app/uploads

# Expose port
EXPOSE 5000

# Start the server
CMD ["npm", "start"]
