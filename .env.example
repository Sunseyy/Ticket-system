# ─────────────────────────────────────────────────────────────────────────────
# Environment Variables - Ticketing System
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and customize for your environment
# Usage: cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ ENVIRONMENT                                                                  │
# └─────────────────────────────────────────────────────────────────────────────┘
# Options: development, production, test
NODE_ENV=development

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ DATABASE CONFIGURATION                                                       │
# └─────────────────────────────────────────────────────────────────────────────┘
DB_HOST=db
DB_PORT=5432
DB_NAME=ticketing
DB_USER=postgres
DB_PASSWORD=postgres

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ BACKEND CONFIGURATION                                                        │
# └─────────────────────────────────────────────────────────────────────────────┘
# Port the backend API listens on (inside container)
BACKEND_PORT=5000

# Comma-separated list of allowed CORS origins
# Example for production: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:80,http://localhost:5173,http://localhost

# Maximum file upload size in bytes (default: 10MB = 10485760)
MAX_FILE_SIZE=10485760

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ FRONTEND CONFIGURATION                                                       │
# └─────────────────────────────────────────────────────────────────────────────┘
# Port the frontend serves on (host machine)
FRONTEND_PORT=80

# Backend API URL (used by React app)
# For local development: http://localhost:5000
# For production: https://api.yourdomain.com
VITE_API_URL=http://localhost:5000

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ PRODUCTION OVERRIDES (uncomment for production)                              │
# └─────────────────────────────────────────────────────────────────────────────┘
# NODE_ENV=production
# DB_PASSWORD=your_secure_password_here
# CORS_ORIGINS=https://yourdomain.com
# VITE_API_URL=https://api.yourdomain.com
